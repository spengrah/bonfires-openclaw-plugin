{
  "name": "bonfires-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "lint": "tsx scripts/spec-lint.ts && tsc --noEmit",
    "test": "tsx scripts/spec-test.ts && node --import tsx --test tests/*.test.ts",
    "test:coverage": "c8 --reporter=json-summary --reporter=json --reports-dir=coverage node --import tsx --test tests/*.test.ts",
    "coverage": "npm run test:coverage",
    "verify:hosted": "tsx scripts/hosted-integration-verify.ts",
    "ingest:bonfires": "tsx scripts/ingest-to-bonfires.ts",
    "gate:traceability": "tsx scripts/gates/traceability-check.ts",
    "gate:quality": "tsx scripts/gates/quality-check.ts",
    "gate:coverage": "tsx scripts/gates/coverage-check.ts",
    "gate:changed-lines": "tsx scripts/gates/changed-lines-coverage-check.ts",
    "gate:mutation-lite": "tsx scripts/gates/mutation-lite-check.ts",
    "gate:diff-escalation": "tsx scripts/gates/diff-aware-escalation-check.ts",
    "gate:anti-gaming": "tsx scripts/gates/anti-gaming-check.ts",
    "gate:review-provenance": "tsx scripts/gates/review-provenance-check.ts .ai/log/review",
    "gate:all": "tsx scripts/gates/gate-all.ts"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  }
}